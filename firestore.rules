rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Highly permissive rules to prevent any permission-denied errors on onSnapshot or WebRTC signalling
    
    match /users/{userId} {
      allow read, write: if true;
    }
    
    match /movies/{movieId} {
      allow read, write: if true;
    }
    
    match /active_viewers/{viewerId} {
      allow read, write: if true;
    }
    
    match /categories/{categoryId} {
      allow read, write: if true;
    }
    
    match /favorites/{favoriteId} {
      allow read, write: if true;
    }
    
    match /watchHistory/{historyId} {
      allow read, write: if true;
    }
    
    match /downloads/{downloadId} {
      allow read, write: if true;
    }
    
    match /notifications/{notificationId} {
      allow read, write: if true;
    }
    
    match /ratings/{ratingId} {
      allow read, write: if true;
    }
    
    match /watchlist/{watchlistId} {
      allow read, write: if true;
    }
    
    match /settings/{settingId} {
      allow read, write: if true;
    }
    
    match /comments/{commentId} {
      allow read, write: if true;
    }
    
    match /comment_likes/{likeId} {
      allow read, write: if true;
    }
    
    match /broadcast/{broadcastId} {
      allow read, write: if true;
    }
    
    match /webrtc_signals/{signalId} {
      allow read, write: if true;
    }
    
    match /biz_shops/{shopId} {
      allow read, write: if true;
    }
    
    match /biz_products/{productId} {
      allow read, write: if true;
    }
    
    match /biz_transactions/{transactionId} {
      allow read, write: if true;
    }
    
    match /biz_wallets/{walletId} {
      allow read, write: if true;
    }
  }
}
