rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ==========================================
    // GLOBAL DEFAULT DENY & SECURITY NET (Pillar 1)
    // ==========================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ==========================================
    // GLOBAL PRIMITIVES & IDENTITY HELPERS (Pillar 3)
    // ==========================================
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        ('email' in request.auth.token && (
          request.auth.token.email.matches('(?i)^ssakalivingstone25@gmail\\.com$') ||
          request.auth.token.email.matches('(?i)^admin@donalisa\\.com$')
        )) ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-\\+\\.\\@]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // ==========================================
    // COLLECTION-SPECIFIC RULES (Pillars 2, 4, 5, 6, 8)
    // ==========================================

    // 1. Users profiles
    function isValidUser(data) {
      return data.uid is string && data.uid == request.auth.uid &&
             data.email is string && data.email.size() > 0 && data.email.size() <= 200 &&
             data.displayName is string && data.displayName.size() <= 100 &&
             (data.role == 'viewer' || data.role == 'admin' || data.role == 'merchant') &&
             (data.createdAt is string || data.createdAt is timestamp);
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && (
        incoming().role == 'viewer' || 
        (incoming().role == 'admin' && (
          incoming().email.matches('(?i)^ssakalivingstone25@gmail\\.com$') ||
          incoming().email.matches('(?i)^admin@donalisa\\.com$')
        ))
      );
      allow update: if (isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role) || isAdmin();
      allow delete: if isAdmin();
    }

    // 2. Movies Catalog
    function isValidMovie(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.description is string && data.description.size() <= 2000 &&
             data.videoUrl is string && data.videoUrl.size() <= 1000 &&
             data.posterUrl is string && data.posterUrl.size() <= 1000 &&
             data.type in ['movie', 'series', 'music'] &&
             data.uploadedBy is string;
    }

    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(movieId) && (request.method == 'delete' || isValidMovie(incoming()));
    }

    // 3. Active Heartbeat Viewers
    function isValidViewer(data) {
      return data.userId == request.auth.uid &&
             data.movieId is string && data.movieId.size() <= 100 &&
             data.lastActive is string;
    }

    match /active_viewers/{viewerId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(viewerId) && viewerId.startsWith(request.auth.uid) && isValidViewer(incoming());
      allow delete: if isSignedIn() && isValidId(viewerId) && viewerId.startsWith(request.auth.uid);
    }

    // 4. Categories list
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(categoryId);
    }

    // 5. User Favorites (Pillar 8: Query Enforcer)
    function isValidFavorite(data) {
      return data.userId == request.auth.uid && data.movieId is string;
    }

    match /favorites/{favoriteId} {
      allow create: if isSignedIn() && isValidId(favoriteId) && isValidFavorite(incoming());
      allow delete: if isSignedIn() && isValidId(favoriteId) && (existing().userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 6. User Watch History (Pillar 8: Query Enforcer)
    function isValidWatchHistory(data) {
      return data.userId == request.auth.uid && data.movieId is string && data.position is number;
    }

    match /watchHistory/{historyId} {
      allow create, update: if isSignedIn() && isValidId(historyId) && isValidWatchHistory(incoming());
      allow delete: if isSignedIn() && isValidId(historyId) && (existing().userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 7. Cached / Synced Downloads
    function isValidDownload(data) {
      return data.userId == request.auth.uid && data.movieId is string;
    }

    match /downloads/{downloadId} {
      allow create: if isSignedIn() && isValidId(downloadId) && isValidDownload(incoming());
      allow delete: if isSignedIn() && isValidId(downloadId) && (existing().userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 8. Notifications Feed
    function isValidNotification(data) {
      return data.title is string && data.title.size() <= 200 &&
             data.message is string && data.message.size() <= 2000;
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(notificationId) && (request.method == 'delete' || isValidNotification(incoming()));
    }

    // 9. Ratings Tracker
    function isValidRating(data) {
      return data.userId == request.auth.uid &&
             data.movieId is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5;
    }

    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() && isValidId(ratingId) && isValidRating(incoming());
      allow delete: if isSignedIn() && isValidId(ratingId) && (existing().userId == request.auth.uid || isAdmin());
    }

    // 10. Play Later Watchlist
    function isValidWatchlist(data) {
      return data.userId == request.auth.uid && data.movieId is string;
    }

    match /watchlist/{watchlistId} {
      allow create: if isSignedIn() && isValidId(watchlistId) && isValidWatchlist(incoming());
      allow delete: if isSignedIn() && isValidId(watchlistId) && (existing().userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // 11. System settings
    match /settings/{settingId} {
      allow read: if true; // Publicly readable (e.g. social links before login)
      allow write: if isAdmin() && isValidId(settingId);
    }

    // 12. Streaming Comments & Reviews
    function isValidComment(data) {
      return data.userId == request.auth.uid &&
             data.userEmail is string && data.userEmail.size() <= 200 &&
             data.movieId is string &&
             data.userName is string && data.userName.size() <= 150 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000;
    }

    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming());
      allow update, delete: if isSignedIn() && isValidId(commentId) && (existing().userId == request.auth.uid || isAdmin());
    }

    // 13. Comment Likes Upvotes
    function isValidCommentLike(data) {
      return data.userId == request.auth.uid && data.commentId is string;
    }

    match /comment_likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(likeId) && isValidCommentLike(incoming());
      allow delete: if isSignedIn() && isValidId(likeId) && (existing().userId == request.auth.uid || isAdmin());
    }

    // 14. Live Studio Broadcast descriptors
    match /broadcast/{broadcastId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidId(broadcastId);
    }

    // 15. Live Signaling (WebRTC Co-Watching)
    function isValidSignal(data) {
      return (data.senderId == request.auth.uid || data.receiverId == request.auth.uid) &&
             data.signal is string && data.signal.size() <= 5000;
    }

    match /webrtc_signals/{signalId} {
      allow create: if isSignedIn() && isValidId(signalId) && isValidSignal(incoming());
      allow read, delete: if isSignedIn() && isValidId(signalId) && (existing().senderId == request.auth.uid || existing().receiverId == request.auth.uid || isAdmin());
    }

    // ==========================================
    // BIZLINK UGANDA DIGITAL MARKETPLACE (CAMPALA)
    // ==========================================

    // 16. Admin Owned Shop Templates
    match /shop_templates/{tempId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(tempId);
    }

    // 17. Businessman applications to own/rent shops
    match /merchant_applications/{appId} {
      allow read, write: if isSignedIn() && isValidId(appId);
    }

    // 18. Registered Stalls / Shops
    match /biz_shops/{shopId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(shopId);
    }

    // 19. Products uploaded by merchants
    match /biz_products/{productId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(productId);
    }

    // 20. Ledger / Rent / Commission payments
    match /biz_transactions/{transactionId} {
      allow read, write: if isSignedIn() && isValidId(transactionId);
    }

    // 21. Wallets ledger
    match /biz_wallets/{walletId} {
      allow read, write: if isSignedIn() && isValidId(walletId);
    }

    // 22. Customer Product Orders
    match /biz_orders/{orderId} {
      allow read, write: if isSignedIn() && isValidId(orderId);
    }

    // 23. Interactive reviews
    match /biz_reviews/{reviewId} {
      allow read: if true;
      allow write: if isSignedIn() && isValidId(reviewId);
    }

    // 24. Audit and platform trace logs
    match /marketplace_logs/{logId} {
      allow read, write: if isSignedIn() && isValidId(logId);
    }

    // 25. BizLink Chat Threads
    match /biz_chats/{chatId} {
      allow read, write: if isSignedIn();
    }

    // 26. BizLink Chat Messages
    match /biz_messages/{messageId} {
      allow read, write: if isSignedIn();
    }

    // 27. BizLink Template Blueprints
    match /template_blueprints/{blueprintId} {
      allow read, write: if isSignedIn() && isValidId(blueprintId);
    }

  }
}
