rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // Pillar 1: Global Catch-all Deny
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // Core Identity Helpers
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // -------------------------------------------------------------------------
    // Pillar 2: Validation Blueprints
    // -------------------------------------------------------------------------
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role is string && data.role in ['viewer', 'admin'] &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidMovie(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() <= 256 &&
             data.description is string && data.description.size() <= 4096 &&
             data.posterUrl is string && data.posterUrl.size() <= 1024 &&
             data.videoUrl is string && data.videoUrl.size() <= 1024 &&
             data.duration is number && data.duration > 0 &&
             data.releaseYear is number && data.releaseYear >= 1900 &&
             data.rating is string && data.rating.size() <= 16 &&
             data.categories is list && data.categories.size() <= 20 &&
             (!('type' in data) || (data.type is string && data.type.size() <= 32)) &&
             (!('artist' in data) || (data.artist is string && data.artist.size() <= 256)) &&
             (!('uploadedBy' in data) || (data.uploadedBy is string && data.uploadedBy.size() <= 128)) &&
             (!('createdAt' in data) || (data.createdAt is string && data.createdAt.size() <= 64)) &&
             (!('backdropUrl' in data) || (data.backdropUrl is string && data.backdropUrl.size() <= 1024));
    }

    function isValidRating(data) {
      return data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid &&
             data.movieId is string && data.movieId.size() <= 128 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.ratedAt is string && data.ratedAt.size() <= 64;
    }

    function isValidComment(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.movieId is string && data.movieId.size() <= 128 &&
             data.text is string && data.text.size() > 0 && data.text.size() <= 1000 &&
             data.userEmail is string && data.userEmail.size() <= 256 &&
             data.userName is string && data.userName.size() <= 128 &&
             data.createdAt is string && data.createdAt.size() <= 64;
    }

    function isValidCommentLike(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.commentId is string && data.commentId.size() <= 128 &&
             data.likedAt is string && data.likedAt.size() <= 64;
    }

    function isValidBroadcast(data) {
      return data.activeMovieId is string && data.activeMovieId.size() <= 128 &&
             data.status is string && data.status in ['live', 'repeat', 'off'] &&
             data.tickerUpdates is string && data.tickerUpdates.size() <= 4096 &&
             data.startedAt is string && data.startedAt.size() <= 64 &&
             (!('channelName' in data) || (data.channelName is string && data.channelName.size() <= 256)) &&
             (!('showTitle' in data) || (data.showTitle is string && data.showTitle.size() <= 256)) &&
             (!('showTime' in data) || (data.showTime is string && data.showTime.size() <= 256)) &&
             (!('scheduleJson' in data) || (data.scheduleJson is string && data.scheduleJson.size() <= 16384)) &&
             (!('adScheduleTimestamps' in data) || (data.adScheduleTimestamps is string && data.adScheduleTimestamps.size() <= 1024)) &&
             (!('adScheduleDuration' in data) || (data.adScheduleDuration is number));
    }

    // -------------------------------------------------------------------------
    // Collection: /users/{userId}
    // Users can read public profile info and edit only their own profile
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming());
    }

    // -------------------------------------------------------------------------
    // Collection: /movies/{movieId}
    // Authenticated users can read public movie data. Only Admins can CRUD.
    // -------------------------------------------------------------------------
    match /movies/{movieId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidId(movieId) && isValidMovie(incoming());
      allow update: if (isAdmin() && isValidMovie(incoming())) || 
                    (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['viewCount']) && incoming().viewCount is number);
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Collection: /active_viewers/{viewerId}
    // Signed-in users can manage their active streaming session presence info
    // -------------------------------------------------------------------------
    match /active_viewers/{viewerId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(viewerId) && incoming().userId == request.auth.uid && incoming().movieId is string && incoming().lastActive is string;
      allow update: if isSignedIn() && incoming().userId == request.auth.uid && existing().userId == request.auth.uid && incoming().lastActive is string;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // Collection: /categories/{categoryId}
    // -------------------------------------------------------------------------
    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // Collection: /favorites/{favoriteId}
    // Strictly scoped to owner
    // -------------------------------------------------------------------------
    match /favorites/{favoriteId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(favoriteId) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection: /watchHistory/{historyId}
    // Strictly scoped to owner progress tracking
    // -------------------------------------------------------------------------
    match /watchHistory/{historyId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(historyId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().userId == existing().userId;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection: /downloads/{downloadId}
    // Offline PWA download tracking
    // -------------------------------------------------------------------------
    match /downloads/{downloadId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(downloadId) && incoming().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection: /notifications/{notificationId}
    // Users can read alerts addressed to them or global broadcast alerts
    // -------------------------------------------------------------------------
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.userId == null);
      allow create, delete: if isAdmin();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }

    // -------------------------------------------------------------------------
    // Collection: /ratings/{ratingId}
    // Signed-in users can read ratings, rate movies they watched, and delete their own ratings
    // -------------------------------------------------------------------------
    match /ratings/{ratingId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(ratingId) && isValidRating(incoming()) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && isValidRating(incoming()) && incoming().userId == request.auth.uid && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection: /watchlist/{watchlistId}
    // Signed-in users can manage their personal "Save for Later" queue
    // -------------------------------------------------------------------------
    match /watchlist/{watchlistId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(watchlistId) && incoming().userId == request.auth.uid;
      allow update: if isSignedIn() && incoming().userId == request.auth.uid && existing().userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // -------------------------------------------------------------------------
    // Collection: /settings/{settingId}
    // -------------------------------------------------------------------------
    match /settings/{settingId} {
      allow read: if settingId == 'global' || (isSignedIn() && settingId == request.auth.uid);
      allow create, update: if (isSignedIn() && settingId == request.auth.uid) || isAdmin();
    }

    // -------------------------------------------------------------------------
    // Collection: /comments/{commentId}
    // -------------------------------------------------------------------------
    match /comments/{commentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(commentId) && isValidComment(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // Collection: /comment_likes/{likeId}
    // -------------------------------------------------------------------------
    match /comment_likes/{likeId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(likeId) && isValidCommentLike(incoming());
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // -------------------------------------------------------------------------
    // Collection: /broadcast/{broadcastId}
    // -------------------------------------------------------------------------
    match /broadcast/{broadcastId} {
      allow read: if true;
      allow create, update: if isAdmin() && isValidBroadcast(incoming());
      allow delete: if isAdmin();
    }
  }
}
